# =============================================================================
# Required
# =============================================================================

# Database (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# NextAuth – required for production; dev fallback exists
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Alternative auth secret (NextAuth accepts either)
# AUTH_SECRET=generate-with-openssl-rand-base64-32

# =============================================================================
# Optional – Auth & APIs
# =============================================================================

# Google OAuth (leave empty for credentials-only demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Fragella API – live perfume search (fallback to local/cache if missing)
FRAGELLA_API_KEY=

# Moyasar payments
MOYASAR_API_KEY=
MOYASAR_WEBHOOK_SECRET=
MOYASAR_WEBHOOK_SECRETS=

# App base URL (emails, checkout callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend – transactional email
RESEND_API_KEY=

# =============================================================================
# Optional – Analytics & Monitoring
# =============================================================================

NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_SENTRY_DSN=

# =============================================================================
# Feature flags (NEXT_PUBLIC_*)
# =============================================================================

NEXT_PUBLIC_VOICE_SEARCH_ENABLED=false
NEXT_PUBLIC_LAZY_PRICE_TABLE=false
NEXT_PUBLIC_LAZY_STEP3_ALLERGY=false
NEXT_PUBLIC_DEFER_POSTHOG=false
NEXT_PUBLIC_DEFER_SENTRY_EXTRAS=false

# =============================================================================
# Optional – Logging
# =============================================================================

LOG_TO_FILE=false
LOG_LEVEL=info
